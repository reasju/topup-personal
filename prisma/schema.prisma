generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  OPERATOR
}

enum TransactionStatus {
  PROCESSING
  PENDING
  SUCCESS
  FAILED
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  name         String
  role         Role          @default(OPERATOR)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@map("users")
}

model Product {
  id            String        @id @default(cuid())
  sku           String        @unique
  buyerSkuCode  String        @unique
  name          String
  category      String
  brand         String
  price         Int
  sellPrice     Int
  provider      String
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]

  @@index([category])
  @@index([brand])
  @@index([isActive])
  @@map("products")
}

model Transaction {
  id              String            @id @default(cuid())
  refId           String            @unique
  userId          String
  productId       String
  customerNo      String
  status          TransactionStatus @default(PROCESSING)
  amount          Int
  providerPrice   Int?
  serialNumber    String?
  providerMessage String?
  rc              String?
  rawRequest      Json?
  rawResponse     Json?
  rawWebhook      Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id])
  product         Product           @relation(fields: [productId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([customerNo])
  @@index([productId, customerNo, status])
  @@map("transactions")
}

model WebhookEvent {
  id          String   @id @default(cuid())
  refId       String
  event       String
  payload     Json
  processedAt DateTime @default(now())

  @@index([refId])
  @@map("webhook_events")
}

model SyncLog {
  id          String   @id @default(cuid())
  status      String
  message     String?
  syncedCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("sync_logs")
}
